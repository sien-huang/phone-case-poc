{
	"name": "phone-case-poc",
	"main": ".next/standalone/server.js",
	"compatibility_date": "2026-03-30",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".next/static"
	},
	"d1_databases": [
		{
			"binding": "phone_case_poc_db",
			"database_name": "phone_case_poc_db",
			"database_id": "d6b6e51d-42ee-4956-9ecf-c5b179e42954",
			"remote": true
		}
	],
	"[[r2_buckets]]": {
		"binding": "UPLOADS",
		"bucket_name": "phone-case-poc-uploads"
	}
}