{
  "name": "phone-case-poc",
  "version": "1.0.0",
  "description": "Phone case wholesale B2B POC",
  "scripts": {
    "dev": "next dev",
    "build": "npm install && next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run type-check && npm run lint && npm run test:coverage && npm run test:e2e",
    "quality": "npm run type-check && npm run lint && npm run test:coverage",
    "quality:e2e": "npm run test:e2e"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@react-pdf/renderer": "^4.3.2",
    "autoprefixer": "^10.4.16",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "next": "^15.0.0",
    "next-intl": "^4.8.3",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.32",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^6.19.2",
    "@swc/helpers": "^0.5.20",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^6.2.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "html-pdf": "^3.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-sitemap": "^4.2.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
