# ⚠️ 安全警告：此文件仅作为模板，切勿在生产环境直接使用！
# 请复制为 .env.local 并修改所有密码和密钥

# Database (Supabase PostgreSQL)
# 获取方式：Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].db.supabase.co:5432/postgres?sslmode=require"

# Admin password (生产环境使用强密码)
ADMIN_PASSWORD=your-secure-password

# Next.js
# 生产环境域名（用于生成正确的 URL 和 sitemap）
NEXT_PUBLIC_BASE_URL=https://yourphonecase.com

# NextAuth.js (生成方式：openssl rand -base64 32 或在线生成)
NEXTAUTH_SECRET=generate-a-secure-random-secret-min-32-chars
NEXTAUTH_URL=https://yourphonecase.com

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Email configuration (SMTP - 用于询盘邮件通知)
# QQ邮箱示例：
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-authorization-code
# Gmail示例：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-authorization-code
ADMIN_EMAIL=admin@yourcompany.com
