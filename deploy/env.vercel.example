# Vercel 环境变量配置示例
# 复制为 .env.vercel 并填入真实值

# ============ 核心配置 ============
DATABASE_URL="postgresql://username:password@host.supabase.co:5432/dbname?sslmode=require"

# ============ 管理员配置 ============
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="your-very-secure-password-here"

# ============ 应用配置 ============
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_SITE_NAME="Phone Case B2B Store"
NEXT_PUBLIC_DEFAULT_LANGUAGE="zh-CN"
NEXT_PUBLIC_SUPPORTED_LANGUAGES="zh-CN,en-US"

# ============ SMTP 邮件配置 (测试用) ============
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="noreply@yourcompany.com"

# ============ 文件上传配置 ============
# 如果使用 S3/OSS 存储图片
UPLOAD_PROVIDER="local" # local | s3 | oss
UPLOAD_MAX_SIZE="10485760" # 10MB

# ============ 可选：监控与分析 ============
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
# QAILOG_TOKEN="your_qa日志token"

# ============ 安全 ============
JWT_SECRET="generate-a-random-secret-here-min-32-chars"
ENCRYPTION_KEY="another-random-key-min-32-chars"