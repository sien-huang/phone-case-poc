# 📋 Vercel 环境变量配置模板
# 复制此文件内容到 Vercel Dashboard → Settings → Environment Variables

# ──────────────────────────────────────
# 数据库（必需）
# ──────────────────────────────────────
# 从 Supabase 获取: Database → Connection string → Connection pooling
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:6543/postgres"

# ──────────────────────────────────────
# Admin 认证（必需）
# ──────────────────────────────────────
# 建议使用强密码（12位以上，包含大小写、数字、符号）
ADMIN_PASSWORD="your-secure-password-here"

# ──────────────────────────────────────
# Next.js 配置（必需）
# ──────────────────────────────────────
# 部署后替换为你的 Vercel 域名
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# ──────────────────────────────────────
# Google Analytics 4（可选）
# ──────────────────────────────────────
# GA4 测量 ID，格式: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# ──────────────────────────────────────
# 邮件通知（可选）
# ──────────────────────────────────────
# SMTP 配置（以 Gmail 为例）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
# Gmail 需要使用应用专用密码（16位），不是登录密码
SMTP_PASS="your-gmail-app-password"
ADMIN_EMAIL="admin@yourcompany.com"

# ──────────────────────────────────────
# 其他配置（按需添加）
# ──────────────────────────────────────
# 例如: Stripe 支付密钥、Recaptcha 密钥等
